class Solution {
    public int[] shuffle(int[] nums, int n) {
        int[] arr = new int[2*n];
        int a=0;
        int b = 0;
        for(int i=0;i<2*n;i++){
            if(i%2==0){
                arr[i] = nums[a];
                a+=1;
            }else{
                arr[i] = nums[n+b];
                b+=1;
            }
        }
       return arr; 
    }
}
