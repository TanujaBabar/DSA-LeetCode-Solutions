class Solution {
   public void rotate(int[][] mat){
        int n = mat.length;
    // Step 1: Transpose =>approach 1 
        //int m = mat[0].length;
        /*for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                mat[i][j] = mat[j][i];
            }
        }*/
    // Step 1: Transpose => approach 2  
        for(int i = 0; i < n; i++){
            for(int j = i; j < n; j++){
                int temp = mat[i][j];
                mat[i][j] = mat[j][i];
                mat[j][i] = temp;
            }
        }
    // Step 2: Reverse each row    
        int start = 0;
        int end = n-1;
        while(start<end){
            for(int k=0;k<n;k++){
            int temp = mat[k][start];
            mat[k][start] = mat[k][end];
            mat[k][end] =temp;
            }
            start++;
            end--;
        }
   }



    public boolean findRotation(int[][] mat, int[][] target) {

// at max we can rotate our matrix 4 times.....
       int n = mat.length;
       int m = mat[0].length;
       for(int c=0;c<4;c++){
        boolean equals = true;
          for(int i=0;i<n;i++){
            for(int j=0;j<m;j++){
                if(mat[i][j] != target[i][j]){
                    equals = false;
                    break;
                }
            }
            if(!equals){
                break;
             }
          }
          if(equals){
                return true;
          }
          rotate(mat);
       } 
       return false;
    }
}
