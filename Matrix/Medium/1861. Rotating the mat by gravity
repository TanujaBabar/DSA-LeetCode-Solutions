        // Step 1: Apply gravity
        for (int i = 0; i < n; i++) {
            int empty = m - 1;

            for (int j = m - 1; j >= 0; j--) {
                if (boxGrid[i][j] == '*') {
                    empty = j - 1;
                } else if (boxGrid[i][j] == '#') {
                    char temp = boxGrid[i][j];
                    boxGrid[i][j] = '.';
                    boxGrid[i][empty] = temp;
                    empty--;
                }
            }
        }

        // Step 2: Rotate
        char[][] rotate = new char[m][n];

        for (int i = 0; i < n; i++) {
            for (int j = 0; j < m; j++) {
                rotate[j][n - i - 1] = boxGrid[i][j];
            }
        }

        return rotate;
        
