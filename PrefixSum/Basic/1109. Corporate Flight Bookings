class Solution {
    public int[] corpFlightBookings(int[][] bookings, int n) {

        // Step 1: Create result array (difference array initially)
        int[] flights = new int[n];

        // Step 2: Apply range updates using difference array technique
        for (int[] booking : bookings) {

            int first = booking[0];   // starting flight (1-based index)
            int last = booking[1];    // ending flight (1-based index)
            int seats = booking[2];   // number of seats to add

            // Add seats at starting index
            flights[first - 1] += seats;

            // Subtract seats just after the ending index (if within bounds)
            // This ensures the effect stops after 'last'
            if (last < n) {
                flights[last] -= seats;
            }
        }

        // Step 3: Convert difference array into actual values using prefix sum
        for (int i = 1; i < n; i++) {
            flights[i] += flights[i - 1];
        }

        // Step 4: Return final result
        return flights;
    }
}
