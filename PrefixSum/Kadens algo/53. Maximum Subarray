class Solution {
    public int maxSubArray(int[] nums) {
        int n = nums.length;

        // 'sum' stores the current subarray sum
        int sum = 0;

        // 'maxsum' stores the maximum subarray sum found so far
        // Initialize with first element to handle all-negative arrays
        int maxsum = nums[0];

        for(int i = 0; i < n; i++){

            // Extend the current subarray by including nums[i]
            sum += nums[i];

            // Update maxsum if current sum is greater
            if(maxsum < sum){
                maxsum = sum;
            }

            // If current sum becomes negative,
            // discard it (start fresh from next index)
            if(sum < 0){
                sum = 0;
            }
        }

        // Return the maximum subarray sum
        return maxsum;
    }
}
