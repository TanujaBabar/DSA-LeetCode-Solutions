class Solution {
    public int maxSubarraySumCircular(int[] nums) {
        int n = nums.length;
        int totalsum = 0;

        // Max subarray (Kadane)
        int sum = 0;
        int maxsum = Integer.MIN_VALUE;
        for(int i = 0; i < n; i++){
            totalsum += nums[i];
            sum += nums[i];
            maxsum = Math.max(maxsum, sum);
            if(sum < 0) sum = 0;
        }

        // Min subarray (Kadane reverse)
        int sum2 = 0;
        int minsum = Integer.MAX_VALUE;
        for(int i = 0; i < n; i++){
            sum2 += nums[i];
            minsum = Math.min(minsum, sum2);
            if(sum2 > 0) sum2 = 0;
        }

        // 🔥 Edge case
        if(maxsum < 0) return maxsum;

        return Math.max(maxsum, totalsum - minsum);
    }
}
