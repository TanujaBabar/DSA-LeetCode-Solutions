//PowerOfTwo nos are 1(2^0),2,4,8,16,32,64...
//In binary this no. contains single '1' like 1,10,100,1000,100000...

class Solution {
    public boolean isPowerOfTwo(int n) {
       String str = Integer.toBinaryString(n);
       int count = 0;
       int m = str.length();
       if(n<=0) return false;
       for(int i=0; i< m; i++){
           if(str.charAt(i)=='1'){
              count++;
           }
       }

     if(count == 1) return true;
     else return false;
    }
}
