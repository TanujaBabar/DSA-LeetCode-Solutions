class Solution {
    public int countKDifference(int[] nums, int k) {
        int n = nums.length;
        int pairs = 0;
        for(int i=0;i<n;i++){
            for(int j=i+1;j<n;j++){
               if(nums[i]-nums[j] == k || nums[j]-nums[i]==k){
                pairs++;
               }
            }
        }
        return pairs;
