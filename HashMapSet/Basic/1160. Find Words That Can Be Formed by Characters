class Solution {
    public int countCharacters(String[] words, String chars) {
        HashMap<Character, Integer> freqChars = new HashMap<>();
        for(int i=0;i<chars.length();i++){
            char ch = chars.charAt(i);
            freqChars.put(ch, freqChars.getOrDefault(ch, 0)+1);
        }
        int count = 0;
        for(String str:words){
            HashMap<Character, Integer> freqStr = new HashMap<>();
            boolean canForm = true;

            for(int i=0;i<str.length();i++){
              char ch = str.charAt(i);
              freqStr.put(ch, freqStr.getOrDefault(ch, 0)+1);

              if(freqChars.getOrDefault(ch, 0) < freqStr.get(ch)){
                  canForm = false;
                  break;
              }
            }
            if(canForm){
                count += str.length();
            }
        }
        
    return count;    
    }
}
