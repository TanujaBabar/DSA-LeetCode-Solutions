class Solution {
    public int[] findThePrefixCommonArray(int[] A, int[] B) {

        /*
         * APPROACH 1 : Brute Force using two boolean arrays
         * -------------------------------------------------
         * Time Complexity  : O(n^2)
         * Space Complexity : O(n)
         *
         * Logic:
         * - Mark elements present till index i in both arrays.
         * - Count how many numbers are present in both prefixes.
         */

        /*
