class Solution {
    public int numJewelsInStones(String jewels, String stones) {
        int n = jewels.length();
        int m = stones.length();
        int i=0;
        int count = 0;
        while(i<m){
            if(jewels.indexOf(stones.charAt(i))!=-1){
                count++;    
            }
            i++;
        }
      return count;  
    }
}
