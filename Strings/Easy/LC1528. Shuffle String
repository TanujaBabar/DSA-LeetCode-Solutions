class Solution {
    public String restoreString(String s, int[] indices) {
        int n = s.length();
        //StringBuilder sb = new StringBuilder();
        char[] arr = new char[n];
        for(int i=0;i<n;i++){
            int idx = indices[i];
            arr[idx]= s.charAt(i);
        }
        return new String(arr);
    }
}
