class Solution {
    public int longestPalindrome(String s) {
        Set<Character> hs = new HashSet<>();
        int n = s.length();
        int count=0;
        for(int i=0;i<n;i++){
            char c = s.charAt(i);
            if(hs.contains(c)){
                hs.remove(c);
                count++;
            }else{
                hs.add(c);
            }
        }
        count *= 2;
        if(!hs.isEmpty()){
            count++;
        }
      return count;  
    }
}
