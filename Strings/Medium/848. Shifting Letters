              sb.add(toadd);
           }
        }
        return sb.toString();*/



        int n = shifts.length;
        char[] res = new char[n];
        int totalshift = 0;
        for(int i=n-1;i >= 0;i--){
            totalshift += shifts[i];
            totalshift = totalshift%26;

            char ch = s.charAt(i);

            int pos = ch - 'a';

            pos = (int)(pos + totalshift)%26;

            res[i] = (char)('a' + pos);

        }
        String ans = "";
        for(int i=0;i<n;i++){
            ans += res[i];
        }
        return ans;
    }
}
