    boolean[] lower = new boolean[26];
    boolean[] upper = new boolean[26]; 
    int count = 0;
    for(char ch: word.toCharArray()){
        if(Character.isLowerCase(ch)){
            lower[ch - 'a'] = true;
        }
        if(Character.isUpperCase(ch)){
            upper[ch - 'A'] = true;
        }
    }
    for(int i=0;i<26;i++){
        if(lower[i] && upper[i]){
            count++;
        }
    }
    return count;
    }
}
