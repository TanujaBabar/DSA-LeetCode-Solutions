    int n = bills.length;
    int count_5 = 0;
    int count_10 = 0;
    int count_20 = 0;
    for(int i=0;i<n;i++){
        if(bills[i] == 5){
           count_5++;
        }else if(bills[i] == 10){
            if(count_5 > 0){
                count_5--;
                count_10++;
            }else{
                return false;
            }
        }else{ // bills[i] == 20
            if(count_5 > 0 && count_10 > 0){
                count_5--;
                count_10--;
                count_20++;
            }else if(count_5 >= 3){ // if we have $5 coins 3/6/9
                count_5-=3;
                count_20++;
            }else{
                return false;
            }

        }
    }
    return true;
    }
}
